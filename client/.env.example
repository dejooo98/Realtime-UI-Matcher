# Leave unset (or empty) for same-origin API (Render single service or Vite dev proxy).
# `npm run dev` at repo root sets VITE_API_PROXY_TARGET + VITE_DEV_PORT automatically.
# VITE_API_PROXY_TARGET=http://127.0.0.1:4000
# VITE_DEV_PORT=5174
#
# Optional: API on another host (no trailing slash), e.g. split frontend/backend:
# VITE_API_URL=https://api.example.com
