# Leave unset (or empty) in local dev: Vite proxies /api to the API origin below.
# `npm run dev` at repo root sets VITE_API_PROXY_TARGET + VITE_DEV_PORT automatically.
# VITE_API_PROXY_TARGET=http://127.0.0.1:4000
# VITE_DEV_PORT=5174
#
# In production, set to your API origin (no trailing slash), e.g.:
# VITE_API_URL=https://api.yourdomain.com
# VITE_API_URL=
